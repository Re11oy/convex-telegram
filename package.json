{
  "name": "convex-telegram",
  "description": "A Telegram bot component for Convex: send messages via the typed Bot API and receive updates through a verified webhook.",
  "repository": "github:Re11oy/convex-telegram",
  "homepage": "https://github.com/Re11oy/convex-telegram#readme",
  "bugs": {
    "url": "https://github.com/Re11oy/convex-telegram/issues"
  },
  "version": "0.1.0",
  "license": "Apache-2.0",
  "keywords": [
    "convex",
    "component",
    "telegram",
    "bot",
    "webhook"
  ],
  "type": "module",
  "main": "./dist/client/index.js",
  "module": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts"
    }
  },
  "scripts": {
    "dev": "convex dev --start 'pnpm run dev:build'",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' -i '**/*.test.ts' -c 'pnpm run build:codegen' --initial",
    "predev": "pnpm run build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "tsc --project ./tsconfig.build.json",
    "build:codegen": "convex codegen --component-dir ./src/component && pnpm run build",
    "build:clean": "pnpm run clean && pnpm run build:codegen",
    "typecheck": "tsc --noEmit && tsc -p example/convex",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck --clearScreen false",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "preversion": "pnpm install && pnpm run build:clean && pnpm run test && pnpm run lint && pnpm run typecheck",
    "alpha": "pnpm version prerelease --preid alpha && pnpm publish --tag alpha && git push --follow-tags",
    "release": "pnpm version patch && pnpm publish && git push --follow-tags"
  },
  "peerDependencies": {
    "convex": ">=1.36.0"
  },
  "dependencies": {
    "@gramio/types": "9.6.1"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "2.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "9.39.2",
    "@types/node": "^24.12.2",
    "chokidar-cli": "3.0.0",
    "convex": "^1.40.0",
    "convex-test": "^0.0.50",
    "eslint": "9.39.2",
    "globals": "17.6.0",
    "pkg-pr-new": "0.0.60",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.55.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
